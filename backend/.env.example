# App Environment
ENVIRONMENT=production
FRONTEND_URL=https://your-frontend-domain.com   # Used as redirect target in invite emails           # Set to "development" to enable reload + debug logging
ALLOWED_ORIGINS=https://your-frontend-domain.com   # Comma-separated list of allowed origins
PORT=8000
LOG_LEVEL=info

# Supabase Configuration
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Redis (optional but strongly recommended in production)
# Without this, rate limits are per-process and multiply with worker count.
# Any Redis-compatible service works (Redis Cloud, Upstash, ElastiCache, etc.)
# REDIS_URL=redis://localhost:6379

# Supabase JWT Secret (required for local token validation — eliminates one
# network call per request). Found at: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# SMTP Email Configuration (for invoice delivery)
# --- Resend (recommended) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USERNAME=resend
SMTP_PASSWORD=re_xxxxxxxxxxxxxxxxxxxx   # your Resend API key
SMTP_FROM=invoices@yourdomain.com       # must be a verified domain in Resend

# --- Gmail fallback (App Password) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx    # 16-char App Password from Google Account
# SMTP_FROM=you@gmail.com
